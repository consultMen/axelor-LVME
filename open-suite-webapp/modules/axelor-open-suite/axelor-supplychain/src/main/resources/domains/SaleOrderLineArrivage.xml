<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/domain-models
  https://axelor.com/xml/ns/domain-models/domain-models_7.1.xsd">

  <module name="supplychain" package="com.axelor.apps.supplychain.db"/>

  <entity name="SaleOrderLineArrivage">
    <many-to-one name="saleOrderLine" ref="com.axelor.apps.sale.db.SaleOrderLine"
      required="true" title="Ligne de vente"/>
    <many-to-one name="purchaseOrderLine"
      ref="com.axelor.apps.purchase.db.PurchaseOrderLine" required="true"
      title="Ligne d'achat (arrivage)"/>
    <decimal name="qtyAllocated" min="0" precision="20" scale="4" title="Qté allouée"/>
    <decimal name="qtyReceived" readonly="true" precision="20" scale="4" title="Qté reçue"
      default="0"/>
  </entity>

</domain-models>
